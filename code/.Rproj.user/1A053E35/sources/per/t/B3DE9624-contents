library(foreach)
library(doFuture)
library(future)
library(dplyr)


run_sim_comparison <- function() {
  
  # 用于存储所有的结果
  # res_list <- list()
  
  
  ## 1. Set up multisession backend
  plan(multisession, workers = parallel::detectCores() - 1)
  registerDoFuture()
  
  ## 2. Parallel foreach with %dopar%
  
  ## 2. Parallel foreach with %dopar%
  results_list <- foreach(
    m = 1:CONFIG$M_sims,
    .combine = dplyr::bind_rows,
    .packages = c("dplyr")
  ) %dopar% {
  #for(m in 1:CONFIG$M_sims) {
    if(m %% 10 == 0) cat(sprintf("Sim %d/%d...\n", m, CONFIG$M_sims))
    
    set.seed(m)
    # 我们主要关心 Adaptive Design 下的对比，因为 Oracle/Naive 的历史和平均是一样的
    mode <- "Adaptive" 
    
    data_acc <- data.frame()
    
    # 初始设计 (Naive)
    t_g1_init <- expand.grid(L1=0:1); t_g1_init$prob_1 <- 0.5
    t_g2_init <- expand.grid(L1=0:1, A1=0:1, L2=0:1); t_g2_init$prob_1 <- 0.5
    
    curr_g <- list(g1=function(x)0.5, g2=function(x,y,z)0.5)
    
    # 存储历史设计表
    hist_g1 <- list()
    hist_g2 <- list()
    
    batches <- CONFIG$N_total / CONFIG$batch_size
    
    for(b in 1:batches) {
      # 1. 记录本轮使用的设计表 (用于计算 Average)
      if (b==1) {
        hist_g1[[b]] <- t_g1_init
        hist_g2[[b]] <- t_g2_init
      } else {
        hist_g1[[b]] <- last_des$t_g1
        hist_g2[[b]] <- last_des$t_g2
      }
      
      # 2. 生成数据
      d_new <- generate_data(CONFIG$batch_size, curr_g, true_params)
      d_new$batch_id <- b
      data_acc <- bind_rows(data_acc, d_new)
      
      # 3. 更新设计
      if(b < batches) {
        q_curr <- estimate_Q(data_acc)
        last_des <- update_design(data_acc, q_curr, CONFIG$weights, CONFIG$epsilon)
        curr_g <- list(g1=last_des$g1, g2=last_des$g2)
      }
    }
    
    # --- 实验结束，开始推断 ---
    
    # --- B. 推断计算 ---
    data_acc_avg <- calculate_averaged_probs(hist_g1, hist_g2, data_acc)
    q_fin <- estimate_Q(data_acc_avg)
    n <- nrow(data_acc_avg)
    
    # Helper for CI & Coverage
    calc_metrics <- function(eic_df, true_val) {
      est <- mean(eic_df)
      var_est <- var(eic_df) / n # Estimator Variance = Var(EIC)/N
      se <- sqrt(var_est)
      
      ci_lower <- est - 1.96 * se
      ci_upper <- est + 1.96 * se
      is_covered <- (true_val >= ci_lower && true_val <= ci_upper)
      
      return(list(est=est, var=var_est, cov=is_covered))
    }
    
    # 1. Historical Method
    eic_hist <- calculate_inference(data_acc_avg, q_fin, use_average_prob = FALSE)
    m1_hist <- calc_metrics(eic_hist$D1, TRUE_PSI[1])
    m2_hist <- calc_metrics(eic_hist$D2, TRUE_PSI[2])
    
    # 2. Averaged Method
    eic_avg <- calculate_inference(data_acc_avg, q_fin, use_average_prob = TRUE)
    m1_avg <- calc_metrics(eic_avg$D1, TRUE_PSI[1])
    m2_avg <- calc_metrics(eic_avg$D2, TRUE_PSI[2])
    
    # --- C. 返回宽格式结果 ---
    return(data.frame(
      Sim = m,
      # Psi 1
      Est1_Hist = m1_hist$est, Var1_Hist = m1_hist$var, Cov1_Hist = m1_hist$cov,
      Est1_Avg  = m1_avg$est,  Var1_Avg  = m1_avg$var,  Cov1_Avg  = m1_avg$cov,
      
      # Psi 2
      Est2_Hist = m2_hist$est, Var2_Hist = m2_hist$var, Cov2_Hist = m2_hist$cov,
      Est2_Avg  = m2_avg$est,  Var2_Avg  = m2_avg$var,  Cov2_Avg  = m2_avg$cov
    ))
  }
  
  return(bind_rows(results_list))
}


    Cov2_Hist = mean(Cov2_Hist),      # <--- Coverage
    Cov2_Avg = mean(Cov2_Avg),         # <--- Coverage
    Cov2_Hist_Oracle = mean((Est2_Hist - 1.96*sqrt(EmpVar2_Hist) <= TRUE_PSI[2]) & (Est2_Hist + 1.96*sqrt(EmpVar2_Hist) >= TRUE_PSI[2])),
    Cov2_Avg_Oracle = mean((Est2_Avg - 1.96*sqrt(EmpVar2_Avg) <= TRUE_PSI[2]) & (Est2_Avg + 1.96*sqrt(EmpVar2_Avg) >= TRUE_PSI[2])),
    VarRed2_Pct = (var(Est2_Hist) - var(Est2_Avg)) / var(Est2_Hist) * 100,
  )

print(as.data.frame(t(summary_comp)))


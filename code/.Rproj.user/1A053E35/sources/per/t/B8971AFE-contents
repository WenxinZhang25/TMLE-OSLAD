# 3.1 估计 Q (Cell Means)
estimate_Q <- function(data) {
  # P(L2 | L1, A1)
  q_l2 <- data %>% 
    group_by(L1, A1) %>% 
    summarise(p_l2_1 = mean(L2), .groups='drop')
  
  # E[Y | L1, A1, L2, A2] & Var[Y]
  q_y <- data %>% 
    group_by(L1, A1, L2, A2) %>% 
    summarise(
      mu_y = mean(Y), 
      var_y = var(Y),
      n_count = n(),
      .groups='drop'
    )
  
  # Simple fill for unobserved cells (MVP only)
  full_grid <- expand.grid(L1=0:1, A1=0:1, L2=0:1, A2=0:1)
  q_y <- left_join(full_grid, q_y, by=c("L1","A1","L2","A2"))
  q_y$mu_y[is.na(q_y$mu_y)] <- mean(data$Y)
  q_y$var_y[is.na(q_y$var_y)] <- var(data$Y)
  
  return(list(q_l2=q_l2, q_y=q_y))
}

# 3.2 A-optimal Design 所需辅助函数
get_var_safe <- function(models, l1, a1, l2, a2) {
  res <- models$q_y %>% filter(L1==l1, A1==a1, L2==l2, A2==a2)
  if(nrow(res) > 0 && !is.na(res$var_y[1])) return(res$var_y[1])
  return(1.0)
}
get_pl2_safe <- function(models, l1, a1) {
  res <- models$q_l2 %>% filter(L1==l1, A1==a1)
  if(nrow(res) > 0 && !is.na(res$p_l2_1[1])) return(res$p_l2_1[1])
  return(0.5)
}


# better hetero case (oracle best for minimizing EIC, not guarantee for minimizing)
true_params <- list(
  p_l1 = 0.5,
  
  # 让 L2 在 (L1,A1) 上更不对称一点
  p_l2_cond = function(l1, a1) {
    if(l1==0 & a1==0) return(0.2)
    if(l1==0 & a1==1) return(0.8)   # A1=1 时 L2 更容易=1
    if(l1==1 & a1==0) return(0.7)
    if(l1==1 & a1==1) return(0.3)   # 这里反过来，增加不对称性
  },
  
  y_dist = function(l1, a1, l2, a2) {
    # --- 均值部分：让 timing effect 对 L1 有异质性 ---
    # baseline
    mu <- 8 + 2*l1 + 1.5*l2
    
    # A1 的效果：对 L1=0 时更大，对 L1=1 时较小
    mu <- mu + (4 + 2*(1 - l1)) * a1   # L1=0 -> +6, L1=1 -> +4
    
    # A2 的效果：对 L1=1 时更大，对 L1=0 时较小
    mu <- mu + (2 + 3*l1) * a2        # L1=0 -> +2, L1=1 -> +5
    
    # 适当保留一点 A1*A2 interaction
    mu <- mu - 1.5 * a1 * a2
    
    # 再加一点 L2*A2 交互，让 (L2=1,A2=1) 在某些 strata 下特别重要
    mu <- mu + 1.5 * l2 * a2
    
    # --- 方差部分：让 "关键 path" 随 L 变化 ---
    sigma <- 1
    
    # 对 Psi2（d2 vs d3），让 L1=0 的 (A1=0,A2=1) 特别 noisy
    if(l1==0 && a1==0 && a2==1) sigma <- 4   # 高噪声但只在 L1=0
    
    # 对 Psi1（d1 vs d2），让 L1=1 的 (A1=1,A2=1) 特别 noisy
    if(l1==1 && a1==1 && a2==1) sigma <- 4   # 高噪声但只在 L1=1
    
    # (A1=0,A2=0) 保持比较稳定，但 L1=1 时稍微大一点
    if(a1==0 && a2==0 && l1==0) sigma <- 0.5
    if(a1==0 && a2==0 && l1==1) sigma <- 1.0
    
    # 其他 cell 维持中等噪声
    return(list(mu=mu, sigma=sigma))
  }
)

# 通用数据生成函数
# g_design 可以是列表包含函数 g1, g2
generate_data <- function(n, g_design, params) {
  d <- data.frame(id = 1:n)
  
  # Stage 1
  d$L1 <- rbinom(n, 1, params$p_l1)
  
  # A1
  if(is.function(g_design$g1)) {
    probs_a1 <- sapply(d$L1, g_design$g1)
  } else {
    probs_a1 <- 0.5 # Default fallback
  }
  d$A1 <- rbinom(n, 1, probs_a1)
  d$prob_A1 <- ifelse(d$A1==1, probs_a1, 1-probs_a1)  # 历史随机化概率
  
  # Stage 2
  probs_l2 <- mapply(params$p_l2_cond, d$L1, d$A1)
  d$L2 <- rbinom(n, 1, probs_l2)
  
  # A2
  if(is.function(g_design$g2)) {
    probs_a2 <- mapply(g_design$g2, d$L1, d$A1, d$L2)
  } else {
    probs_a2 <- 0.5
  }
  d$A2 <- rbinom(n, 1, probs_a2)
  d$prob_A2 <- ifelse(d$A2==1, probs_a2, 1-probs_a2)  # 历史随机化概率
  
  # Outcome
  y_params <- mapply(params$y_dist, d$L1, d$A1, d$L2, d$A2, SIMPLIFY = FALSE)
  mus <- sapply(y_params, function(x) x$mu)
  sigmas <- sapply(y_params, function(x) x$sigma)
  d$Y <- rnorm(n, mean = mus, sd = sigmas)
  
  return(d)
}


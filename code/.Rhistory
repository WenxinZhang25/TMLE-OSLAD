# ==============================================================================
# 8. Monte Carlo Loop & Report
# ==============================================================================
cat(sprintf("Starting Monte Carlo Simulation (M=%d)...\n", CONFIG$M_sims))
library(foreach)
library(doFuture)
library(future)
plan(multisession, workers = parallel::detectCores() - 1)
registerDoFuture()
results_list <- foreach(
m = 1:CONFIG$M_sims,
.combine = dplyr::bind_rows,
.packages = c("dplyr")
) %dopar% {
if (m %% 10 == 0) cat(sprintf("Sim %d/%d...\n", m, CONFIG$M_sims))
set.seed(m)
res_naive  <- run_single_experiment("Naive")
set.seed(m)
res_oracle <- run_single_experiment("Oracle")
set.seed(m)
res_adapt  <- run_single_experiment("Adaptive")
set.seed(m)
res_gbar_drv <- run_single_experiment("Adaptive_gbar_driven")
set.seed(m)
res_gbar_stb <- run_single_experiment("Adaptive_gbar_stabilized")
bind_rows(res_naive, res_oracle, res_adapt, res_gbar_drv, res_gbar_stb)
# bind_rows(res_naive, res_oracle)
}
full_results <- bind_rows(results_list)
# ==============================================================================
# 9. 结果汇总与展示
# ==============================================================================
summary_table <- full_results %>%
group_by(Design) %>%
summarise(
# ---------------- Psi 1 ----------------
Truth_Psi1 = TRUE_PSI[1],
Bias1_Hist = mean(Est1_Hist) - TRUE_PSI[1],
Bias1_Avg  = mean(Est1_Avg)  - TRUE_PSI[1],
EmpVar1_Hist = var(Est1_Hist),   # Monte Carlo variance
EmpVar1_Avg  = var(Est1_Avg),
AvgEstVar1_Hist = mean(Var1_Hist),  # 平均估计方差
AvgEstVar1_Avg  = mean(Var1_Avg),
Coverage1_Hist = mean(Cov1_Hist),
Coverage1_Avg  = mean(Cov1_Avg),
Oracle_Coverage1_Hist = mean(
abs(Est1_Hist - TRUE_PSI[1]) <= 1.96 * sqrt(EmpVar1_Hist)
),
Oracle_Coverage1_Avg = mean(
abs(Est1_Avg  - TRUE_PSI[1]) <= 1.96 * sqrt(EmpVar1_Avg)
),
# ---------------- Psi 2 ----------------
Truth_Psi2 = TRUE_PSI[2],
Bias2_Hist = mean(Est2_Hist) - TRUE_PSI[2],
Bias2_Avg  = mean(Est2_Avg)  - TRUE_PSI[2],
EmpVar2_Hist = var(Est2_Hist),
EmpVar2_Avg  = var(Est2_Avg),
AvgEstVar2_Hist = mean(Var2_Hist),
AvgEstVar2_Avg  = mean(Var2_Avg),
Coverage2_Hist = mean(Cov2_Hist),
Coverage2_Avg  = mean(Cov2_Avg),
Oracle_Coverage2_Hist = mean(
abs(Est2_Hist - TRUE_PSI[2]) <= 1.96 * sqrt(EmpVar2_Hist)
),
Oracle_Coverage2_Avg = mean(
abs(Est2_Avg  - TRUE_PSI[2]) <= 1.96 * sqrt(EmpVar2_Avg)
),
.groups = "drop"
)
# 展开 summary_table 的 variance 结果
var_long <- summary_table %>%
select(Design,
EmpVar1_Hist, EmpVar1_Avg,
EmpVar2_Hist, EmpVar2_Avg) %>%
pivot_longer(
cols = starts_with("EmpVar"),
names_to  = c("Psi", "Estimator"),
names_pattern = "EmpVar(\\d)_(.*)",  # EmpVar1_Hist -> Psi=1 Estimator=Hist
values_to = "EmpVar"
) %>%
mutate(
Psi_label = ifelse(Psi == "1", "Psi1", "Psi2")
)
# 计算 A-optimal weighted variance: w1*Var(Psi1) + w2*Var(Psi2)
weighted_var <- var_long %>%
mutate(
weight = ifelse(Psi == "1", CONFIG$weights[1], CONFIG$weights[2])
) %>%
group_by(Design, Estimator) %>%
summarise(
A_weighted_Var = sum(weight * EmpVar),
.groups = "drop"
) %>%
mutate(
Design_Est = paste(Design, Estimator, sep = "_")
)
ggplot(
weighted_var,
aes(x = Design_Est, y = A_weighted_Var, fill = Estimator)
) +
geom_col(position = "dodge") +
theme_minimal() +
labs(
title = "A-optimal weighted variance by Design & Estimator",
y = "w1 * Var(Psi1) + w2 * Var(Psi2)",
x = "Design × Estimator"
) +
theme(axis.text.x = element_text(angle = 30, hjust = 1))
View(summary_table)
full_results <- bind_rows(results_list)
# ==============================================================================
# 9. 结果汇总与展示

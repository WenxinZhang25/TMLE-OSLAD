## 2. 用 true_params 构造 q_truth（解析的 E[Y|·], Var[Y|·], P(L2|·)）
q_truth <- build_q_truth_from_params(true_params)
## 3. 基于 q_truth 做 oracle design
cat("Calculating Oracle Design from true_params...\n")
oracle_design_obj <- update_design(
accumulated_data = NULL,     # 现在其实没用到，可以给 NULL
current_Q        = q_truth,  # 真 Q
weights          = CONFIG$weights,
# epsilon          = 0.01
epsilon          = 0.05
)
oracle_g1_func <- oracle_design_obj$g1
oracle_g2_func <- oracle_design_obj$g2
# ==============================================================================
# 7. 单次实验运行函数 (Single Simulation Run)
# ==============================================================================
run_single_experiment <- function(mode) {
data_acc <- data.frame()
# -------- 1. 初始化设计 & 历史 t_g 表 --------
if (mode == "Naive") {
curr_g <- list(
g1 = function(x) 0.5,
g2 = function(x,y,z) 0.5
)
t_g1_init <- expand.grid(L1 = 0:1); t_g1_init$prob_1 <- 0.5
t_g2_init <- expand.grid(L1 = 0:1, A1 = 0:1, L2 = 0:1); t_g2_init$prob_1 <- 0.5
# 注意：一开始就放进 history，保证 length(hist_g1) >= 1 且有 L1 列
hist_g1 <- list(t_g1_init)
hist_g2 <- list(t_g2_init)
} else if (mode == "Oracle") {
curr_g <- list(
g1 = oracle_g1_func,
g2 = oracle_g2_func
)
# 用 oracle 的 design table 当作每一批的 design
t_g1_init <- oracle_design_obj$t_g1
t_g2_init <- oracle_design_obj$t_g2
hist_g1 <- list(t_g1_init)
hist_g2 <- list(t_g2_init)
} else if (mode == "Adaptive") {
curr_g <- list(
g1 = function(x) 0.5,
g2 = function(x,y,z) 0.5
)
t_g1_init <- expand.grid(L1 = 0:1); t_g1_init$prob_1 <- 0.5
t_g2_init <- expand.grid(L1 = 0:1, A1 = 0:1, L2 = 0:1); t_g2_init$prob_1 <- 0.5
hist_g1 <- list(t_g1_init)
hist_g2 <- list(t_g2_init)
last_des <- list(t_g1 = t_g1_init, t_g2 = t_g2_init)
} else if (mode == "Adaptive_gbar_driven") {
# 新的：meta-level oracle-targeting 版本（方式 B）
curr_g <- list(g1 = function(x) 0.5,
g2 = function(x,y,z) 0.5)
# 为 gbar_driven 保存 history t_g 表
t_g1_init <- expand.grid(L1 = 0:1)
t_g1_init$prob_1 <- 0.5
t_g2_init <- expand.grid(L1 = 0:1, A1 = 0:1, L2 = 0:1)
t_g2_init$prob_1 <- 0.5
hist_g1 <- list(t_g1_init)
hist_g2 <- list(t_g2_init)
last_des <- list(t_g1 = t_g1_init, t_g2 = t_g2_init)
} else if (mode == "Adaptive_gbar_stabilized") {
# oracle 平均 benchmark 的版本（用 update_design_stabilized_avg）
curr_g <- list(
g1 = function(x) 0.5,
g2 = function(x,y,z) 0.5
)
t_g1_init <- expand.grid(L1 = 0:1); t_g1_init$prob_1 <- 0.5
t_g2_init <- expand.grid(L1 = 0:1, A1 = 0:1, L2 = 0:1); t_g2_init$prob_1 <- 0.5
hist_g1 <- list(t_g1_init)
hist_g2 <- list(t_g2_init)
last_des <- list(t_g1 = t_g1_init, t_g2 = t_g2_init)
oracle_hist_g1 <- list()
oracle_hist_g2 <- list()
oracle_weights <- NULL
} else {
stop("Unknown mode in run_single_experiment")
}
batches <- CONFIG$N_total / CONFIG$batch_size
# ==== NEW: 仅在 Adaptive 下记录 design 历史，用于 ḡ ====
# hist_g1 <- list()
# hist_g2 <- list()
# if (mode == "Adaptive") {
#   t_g1_init <- expand.grid(L1=0:1); t_g1_init$prob_1 <- 0.5
#   t_g2_init <- expand.grid(L1=0:1, A1=0:1, L2=0:1); t_g2_init$prob_1 <- 0.5
#   last_des <- list(t_g1 = t_g1_init, t_g2 = t_g2_init)
# }
# -------- 2. 按 batch 生成数据并更新设计 --------
for(b in 1:batches) {
d_batch <- generate_data(CONFIG$batch_size, curr_g, true_params)
d_batch$batch <- b
data_acc <- dplyr::bind_rows(data_acc, d_batch)
# 如果是 gbar_driven 版本，先把当前 design 表存进 history
# ====== Naive / Oracle：design 不变，但 history 要补满 ======
if (mode %in% c("Naive", "Oracle") && b < batches) {
hist_g1[[b + 1]] <- t_g1_init
hist_g2[[b + 1]] <- t_g2_init
}
if (mode == "Adaptive"  && b < batches) {
# if (b == 1) {
#   hist_g1[[b]] <- last_des$t_g1
#   hist_g2[[b]] <- last_des$t_g2
# } else {
#   hist_g1[[b]] <- last_des$t_g1
#   hist_g2[[b]] <- last_des$t_g2
# }
q_curr <- estimate_Q(data_acc)
des_up <- update_design(data_acc, q_curr, CONFIG$weights, CONFIG$epsilon)
curr_g <- list(g1 = des_up$g1, g2 = des_up$g2)
last_des <- des_up
hist_g1[[b + 1]] <- des_up$t_g1
hist_g2[[b + 1]] <- des_up$t_g2
}
if (b < batches && mode == "Adaptive_gbar_driven") {
q_curr <- estimate_Q(data_acc)
des_up <- update_design_gbar_driven(
hist_g1 = hist_g1,
hist_g2 = hist_g2,
q_curr  = q_curr,
weights = CONFIG$weights,
epsilon = CONFIG$epsilon,
b       = b
)
curr_g <- list(g1 = des_up$g1, g2 = des_up$g2)
last_des <- list(t_g1 = des_up$t_g1, t_g2 = des_up$t_g2)
hist_g1[[b + 1]] <- des_up$t_g1
hist_g2[[b + 1]] <- des_up$t_g2
}
if (b < batches && mode == "Adaptive_gbar_stabilized") {
q_curr <- estimate_Q(data_acc)
des_up <- update_design_stabilized_avg(
accumulated_data = data_acc,
current_Q        = q_curr,
weights          = CONFIG$weights,
epsilon          = CONFIG$epsilon,
hist_g1          = hist_g1,
hist_g2          = hist_g2,
oracle_hist_g1   = oracle_hist_g1,
oracle_hist_g2   = oracle_hist_g2,
oracle_weights   = oracle_weights
)
curr_g <- list(g1 = des_up$g1, g2 = des_up$g2)
last_des <- list(t_g1 = des_up$t_g1, t_g2 = des_up$t_g2)
hist_g1[[b + 1]] <- des_up$t_g1
hist_g2[[b + 1]] <- des_up$t_g2
oracle_hist_g1 <- des_up$oracle_hist_g1
oracle_hist_g2 <- des_up$oracle_hist_g2
oracle_weights <- des_up$oracle_weights
}
}
# -------- 3. 实验结束：统一算 Hist / Avg 两种 estimator --------
n <- nrow(data_acc)
## 3.1 Historical weights estimator
q_hist   <- estimate_Q(data_acc)
eic_hist <- calculate_inference(data_acc, q_hist, use_average_prob = FALSE)
est1_hist <- mean(eic_hist$D1)
est2_hist <- mean(eic_hist$D2)
var1_hist <- var(eic_hist$D1) / n
var2_hist <- var(eic_hist$D2) / n
ci1_hist <- c(est1_hist - 1.96 * sqrt(var1_hist),
est1_hist + 1.96 * sqrt(var1_hist))
ci2_hist <- c(est2_hist - 1.96 * sqrt(var2_hist),
est2_hist + 1.96 * sqrt(var2_hist))
cov1_hist <- (TRUE_PSI[1] >= ci1_hist[1] && TRUE_PSI[1] <= ci1_hist[2])
cov2_hist <- (TRUE_PSI[2] >= ci2_hist[1] && TRUE_PSI[2] <= ci2_hist[2])
## 3.2 Average design estimator (所有 design 都走这一步)
data_acc_avg <- calculate_averaged_probs(hist_g1, hist_g2, data_acc)
q_avg        <- estimate_Q(data_acc_avg)
eic_avg      <- calculate_inference(data_acc_avg, q_avg, use_average_prob = TRUE)
est1_avg <- mean(eic_avg$D1)
est2_avg <- mean(eic_avg$D2)
var1_avg <- var(eic_avg$D1) / n
var2_avg <- var(eic_avg$D2) / n
ci1_avg <- c(est1_avg - 1.96 * sqrt(var1_avg),
est1_avg + 1.96 * sqrt(var1_avg))
ci2_avg <- c(est2_avg - 1.96 * sqrt(var2_avg),
est2_avg + 1.96 * sqrt(var2_avg))
cov1_avg <- (TRUE_PSI[1] >= ci1_avg[1] && TRUE_PSI[1] <= ci1_avg[2])
cov2_avg <- (TRUE_PSI[2] >= ci2_avg[1] && TRUE_PSI[2] <= ci2_avg[2])
# -------- 4. 返回，两种 estimator 都带回去 --------
return(data.frame(
Design = mode,
Est1_Hist = est1_hist,
Est2_Hist = est2_hist,
Var1_Hist = var1_hist,
Var2_Hist = var2_hist,
Cov1_Hist = cov1_hist,
Cov2_Hist = cov2_hist,
Est1_Avg  = est1_avg,
Est2_Avg  = est2_avg,
Var1_Avg  = var1_avg,
Var2_Avg  = var2_avg,
Cov1_Avg  = cov1_avg,
Cov2_Avg  = cov2_avg
))
